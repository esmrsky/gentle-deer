---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="Admin Login">
  <div class="min-h-[70vh] flex flex-col items-center justify-center bg-background px-4 py-12" data-ps="src/pages/login.astro:owbrec">
    <div class="w-full max-w-md bg-surface p-8 rounded-[8px] shadow-sm border border-border" data-ps="src/pages/login.astro:owbreb">
      <div class="text-center mb-8" data-ps="src/pages/login.astro:owbrea">
        <h1 class="text-3xl font-serif font-bold text-foreground" data-ps="src/pages/login.astro:p2oje5">Admin Login</h1>
        <p class="text-muted-foreground mt-2" data-ps="src/pages/login.astro:mww4ng">Sign in to manage your site</p>
      </div>
      
      <form id="login-form" class="space-y-5">
        <div data-ps="src/pages/login.astro:owbre9">
          <label class="block text-sm font-medium text-foreground mb-1.5" for="email" data-ps="src/pages/login.astro:kelfcq">Email Address</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required 
            class="w-full px-4 py-2.5 border border-border rounded-[6px] focus:ring-2 focus:ring-primary focus:border-primary bg-surface outline-none transition-all" 
            placeholder="admin@example.com"
          />
        </div>
        
        <div data-ps="src/pages/login.astro:owbre8">
          <label class="block text-sm font-medium text-foreground mb-1.5" for="password" data-ps="src/pages/login.astro:67rkle">Password</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            required 
            class="w-full px-4 py-2.5 border border-border rounded-[6px] focus:ring-2 focus:ring-primary focus:border-primary bg-surface outline-none transition-all" 
            placeholder="••••••••"
          />
        </div>
        
        <button type="submit" class="w-full btn-primary py-3 mt-2" id="submit-btn" data-ps="src/pages/login.astro:1fvzzl">
          Sign In to Dashboard
        </button>
        
        <div id="error-message" class="text-red-600 bg-red-50 px-4 py-3 rounded-[6px] text-sm text-center hidden mt-4 border border-red-100" data-ps="src/pages/login.astro:owbre7"></div>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  import { authClient } from '@/lib/pagesmith-auth/client';

  const form = document.getElementById('login-form');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorMsg = document.getElementById('error-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    if (submitBtn) {
      submitBtn.textContent = 'Signing in...';
      submitBtn.disabled = true;
    }
    if (errorMsg) errorMsg.classList.add('hidden');

    try {
      const { error } = await authClient.signIn.email({
        email,
        password,
      });

      if (error) {
        throw new Error(error.message || 'Invalid email or password');
      }

      // Successful login will redirect to admin
      window.location.href = '/admin';
    } catch (err: any) {
      if (errorMsg) {
        errorMsg.textContent = err.message || 'An error occurred during login. Please try again.';
        errorMsg.classList.remove('hidden');
      }
      if (submitBtn) {
        submitBtn.textContent = 'Sign In to Dashboard';
        submitBtn.disabled = false;
      }
    }
  });
</script>
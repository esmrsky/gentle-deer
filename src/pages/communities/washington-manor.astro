---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CommunityHero from '@/components/communities/CommunityHero.astro';
import CommunityFeatures from '@/components/communities/CommunityFeatures.astro';
import CommunityHomes from '@/components/communities/CommunityHomes.astro';
import ResidentSection from '@/components/communities/ResidentSection.astro';
import ExploreCommunities from '@/components/communities/ExploreCommunities.astro';

const community = {
  title: 'Washington Manor',
  subtitle: 'SMALL TOWN LIVING',
  location: 'Washington Court House, Ohio',
  phone: '(740) 954-9260',
  communityType: 'All ages',
  established: '1988',
  petPolicy: 'Pets welcome',
  officeHours: 'M–F 9am–5pm',
  heroImage: 'https://cdn.pagesmith.app/69b93246/images/hero-community-ad9AFtHhG4fpSz2z6YeCHE-1536.webp',
  badge: undefined,
};

const description = `Washington Manor brings the warmth of small-town Ohio living to manufactured home affordability. Quiet streets, mature trees, and a community where your neighbors actually know your name.

Located in Washington Court House, residents enjoy the slower pace of a small town with the security of a well-managed Greenlawn community. Community parking, pet-friendly policies, and friendly neighbors round out the experience.

For those who want the charm of small-town Ohio without sacrificing community quality, Washington Manor delivers.`;

const features = [
  { label: 'Quiet Streets', description: 'A peaceful, low-traffic environment.' },
  { label: 'Mature Trees', description: 'Shaded streets and natural beauty.' },
  { label: 'Pet Friendly', description: 'Dogs and cats welcome.' },
  { label: 'On-site Management', description: 'Responsive team always available.' },
  { label: 'Community Parking', description: 'Ample parking for residents and guests.' },
  { label: 'Friendly Neighbors', description: 'A genuine small-town community feel.' },
];

const homes = [
  {
    image: 'https://cdn.pagesmith.app/69b93246/images/BanfIPykQXQEIMCU-1536.webp',
    status: 'Pre-Owned',
    price: '$56,200',
    address: '94 Jamison Rd #14, Washington Court House, OH',
    specs: '2 bed · 2 bath · 1,040 sqft',
    url: 'https://greenlawnhomes-udyhps8u.manus.space/homes/4',
  },
];

const exploreCommunities = [
  {
    category: '55+ COMMUNITY',
    name: 'Enchanted Acres',
    location: 'Central Ohio',
    url: '/communities/enchanted-acres',
  },
  {
    category: 'COUNTRY LIVING',
    name: 'Foxlair Farms',
    location: 'Orient, Ohio',
    url: '/communities/foxlair-farms',
  },
  {
    category: 'RURAL RETREAT',
    name: 'Wagon Wheel',
    location: 'Mt Sterling, Ohio',
    url: '/communities/wagon-wheel',
  },
];
---

<BaseLayout title="Washington Manor | Greenlawn Homes" description="Washington Manor brings the warmth of small-town Ohio living to manufactured home affordability. Quiet streets, mature trees, and a community where your neighbors actually know your name.">
  <CommunityHero {...community} />

  <section class="py-16 md:py-20 bg-background">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-[800px]">
        <h2 class="text-[32px] font-semibold text-foreground mb-6">
          Small town charm. Big community feel.
        </h2>
        <div class="space-y-4 text-[16px] text-muted-foreground leading-relaxed">
          {description.split('\n\n').map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </div>

      <div class="mt-12 p-6 bg-surface rounded-[8px] border border-border max-w-[600px]">
        <h3 class="text-[18px] font-semibold text-foreground mb-4">Community Details</h3>
        <dl class="space-y-3 text-[14px]">
          <div class="flex gap-4">
            <dt class="text-muted-foreground w-32">Address</dt>
            <dd class="text-foreground">94 Jamison Rd, Washington Court House, OH 43160</dd>
          </div>
          <div class="flex gap-4">
            <dt class="text-muted-foreground w-32">Phone</dt>
            <dd>
              <a href="tel:7409549260" class="text-primary hover:underline font-semibold">(740) 954-9260</a>
            </dd>
          </div>
          <div class="flex gap-4">
            <dt class="text-muted-foreground w-32">Office Hours</dt>
            <dd class="text-foreground">M–F 9am–5pm</dd>
          </div>
          <div class="flex gap-4">
            <dt class="text-muted-foreground w-32">Community Manager</dt>
            <dd class="text-foreground">[TBD Manager Name]</dd>
          </div>
          <div class="flex gap-4">
            <dt class="text-muted-foreground w-32">Homes Available</dt>
            <dd class="text-foreground font-semibold">2 available now</dd>
          </div>
        </dl>
        <div class="mt-6">
          <a
            href="/shop-homes"
            class="inline-flex items-center gap-2 bg-primary text-primary-foreground rounded-[6px] px-[20px] py-[10px] text-[14px] font-semibold hover:bg-primary-hover transition-colors"
          >
            Check Availability
          </a>
        </div>
      </div>
    </div>
  </section>

  <CommunityFeatures features={features} />
  <CommunityHomes homes={homes} communityName="Washington Manor" />
  <ResidentSection phone="(740) 954-9260" managerName="[TBD Manager Name]" communityName="Washington Manor" />
  <ExploreCommunities communities={exploreCommunities} />
</BaseLayout>

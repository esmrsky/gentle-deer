---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CommunityHero from '@/components/community/CommunityHero.astro';
import CommunityFeatures from '@/components/community/CommunityFeatures.astro';
import CommunityHomes from '@/components/community/CommunityHomes.astro';

---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const runtime = Astro.locals.runtime;
if (!runtime?.env?.DB) {
  return new Response('Database unavailable', { status: 503 });
}

if (!Astro.locals.user) {
  return Astro.redirect('/login/');
}

const { id } = Astro.params;
const cleanId = id?.replace(/\/$/, '');
let home = null;
let error = '';

try {
  home = await runtime.env.DB.prepare('SELECT * FROM inventory_homes WHERE id = ?').bind(cleanId).first();
} catch (e) {
  console.error(e);
}

if (!home) {
  return Astro.redirect('/admin/inventory/');
}

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action')?.toString();

    if (action === 'delete') {
      await runtime.env.DB.prepare('DELETE FROM inventory_homes WHERE id = ?').bind(cleanId).run();
      return Astro.redirect('/admin/inventory/');
    }

    const title = formData.get('title')?.toString() || '';
    const address = formData.get('address')?.toString() || title;
    const price = formData.get('price')?.toString() || '';
    const status = formData.get('status')?.toString() || 'Available';
    const community = formData.get('community')?.toString() || '';
    const beds = parseInt(formData.get('beds')?.toString() || '0', 10);
    const baths = parseInt(formData.get('baths')?.toString() || '0', 10);
    const sqft = parseInt(formData.get('sqft')?.toString() || '0', 10);
    const image = formData.get('image')?.toString() || '';
    const description = formData.get('description')?.toString() || '';

    if (!title || !price) {
      error = 'Title and Price are required.';
    } else {
      await runtime.env.DB.prepare(`
        UPDATE inventory_homes SET 
          title = ?, address = ?, price = ?, status = ?, 
          community = ?, beds = ?, baths = ?, sqft = ?, 
          image = ?, description = ?
        WHERE id = ?
      `).bind(title, address, price, status, community, beds, baths, sqft, image, description, cleanId).run();
      
      return Astro.redirect('/admin/inventory/');
    }
  } catch (e) {
    console.error(e);
    error = 'Failed to update home. Please try again.';
  }
}
---

<BaseLayout title={`Edit ${home.title} | Inventory`} noIndex={true}>
  <Container class="max-w-[800px] py-12">
    <div class="mb-8 flex justify-between items-end" data-ps="src/pages/admin/inventory/[id].astro:qwjyjs">
      <div data-ps="src/pages/admin/inventory/[id].astro:qwjyjr">
        <a href="/admin/inventory/" class="text-primary hover:underline text-sm font-semibold mb-4 inline-block" data-ps="src/pages/admin/inventory/[id].astro:ddux9w">← Back to Inventory</a>
        <h1 class="text-3xl font-bold font-serif" data-ps="src/pages/admin/inventory/[id].astro:hal9rm">Edit Home</h1>
      </div>
      <form method="POST" onsubmit="return confirm('Are you sure you want to delete this home? This cannot be undone.');">
        <input type="hidden" name="action" value="delete" />
        <button type="submit" class="text-red-600 hover:text-red-800 font-semibold text-sm underline px-2 py-1" data-ps="src/pages/admin/inventory/[id].astro:5svt2j">Delete Home</button>
      </form>
    </div>

    {error && (
      <div class="bg-red-50 text-red-700 p-4 rounded-lg border border-red-200 mb-6" data-ps="src/pages/admin/inventory/[id].astro:qwjyjq">
        {error}
      </div>
    )}

    <form method="POST" class="bg-surface rounded-[8px] border border-border p-8 space-y-6">
      <input type="hidden" name="action" value="update" />
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/pages/admin/inventory/[id].astro:qwjyjp">
        <div data-ps="src/pages/admin/inventory/[id].astro:qwjyjo">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtsik">Title *</label>
          <input type="text" name="title" value={home.title} required class="w-full px-4 py-2 border rounded-lg" />
        </div>
        <div data-ps="src/pages/admin/inventory/[id].astro:qwjyjn">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtsij">Price *</label>
          <input type="text" name="price" value={home.price} required class="w-full px-4 py-2 border rounded-lg" />
        </div>
        
        <div data-ps="src/pages/admin/inventory/[id].astro:oc4a17">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtshx">Address</label>
          <input type="text" name="address" value={home.address} class="w-full px-4 py-2 border rounded-lg" />
        </div>
        <div data-ps="src/pages/admin/inventory/[id].astro:oc4a18">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtshw">Status</label>
          <select name="status" class="w-full px-4 py-2 border rounded-lg bg-white">
            <option value="Available" selected={home.status === 'Available'}>Available</option>
            <option value="New" selected={home.status === 'New'}>New</option>
            <option value="Pending" selected={home.status === 'Pending'}>Pending</option>
            <option value="Sold" selected={home.status === 'Sold'}>Sold</option>
          </select>
        </div>

        <div data-ps="src/pages/admin/inventory/[id].astro:oc4a19">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtshv">Community</label>
          <input type="text" name="community" value={home.community} class="w-full px-4 py-2 border rounded-lg" />
        </div>
        <div class="grid grid-cols-3 gap-4" data-ps="src/pages/admin/inventory/[id].astro:oc4a1a">
          <div data-ps="src/pages/admin/inventory/[id].astro:oc4a1b">
            <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtshu">Beds</label>
            <input type="number" name="beds" value={home.beds} class="w-full px-4 py-2 border rounded-lg" />
          </div>
          <div data-ps="src/pages/admin/inventory/[id].astro:oc4a1c">
            <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtsht">Baths</label>
            <input type="number" name="baths" value={home.baths} class="w-full px-4 py-2 border rounded-lg" />
          </div>
          <div data-ps="src/pages/admin/inventory/[id].astro:oc4a1d">
            <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtshs">Sq Ft</label>
            <input type="number" name="sqft" value={home.sqft} class="w-full px-4 py-2 border rounded-lg" />
          </div>
        </div>

        <div class="md:col-span-2" data-ps="src/pages/admin/inventory/[id].astro:oc4a1e">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtshr">Main Image URL</label>
          <input type="url" name="image" value={home.image} class="w-full px-4 py-2 border rounded-lg" />
          {home.image && (
            <img src={home.image} alt="Preview" class="mt-4 w-32 h-32 object-cover rounded border border-border" data-ps="src/pages/admin/inventory/[id].astro:tet2v9" />
          )}
        </div>

        <div class="md:col-span-2" data-ps="src/pages/admin/inventory/[id].astro:oc4a1f">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/[id].astro:svtshq">Description</label>
          <textarea name="description" rows="5" class="w-full px-4 py-2 border rounded-lg">{home.description}</textarea>
        </div>
      </div>

      <div class="pt-4 border-t border-border flex justify-end gap-4" data-ps="src/pages/admin/inventory/[id].astro:oc4a1g">
        <a href="/admin/inventory/" class="px-6 py-3 rounded-lg font-semibold text-foreground hover:bg-secondary transition-colors" data-ps="src/pages/admin/inventory/[id].astro:ddux9x">Cancel</a>
        <button type="submit" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-hover transition-colors" data-ps="src/pages/admin/inventory/[id].astro:5svt2i">
          Save Changes
        </button>
      </div>
    </form>
  </Container>
</BaseLayout>
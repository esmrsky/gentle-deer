---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const runtime = Astro.locals.runtime;
if (!runtime?.env?.DB) {
  return new Response('Database unavailable', { status: 503 });
}

if (!Astro.locals.user) {
  return Astro.redirect('/login/');
}

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = formData.get('title')?.toString() || '';
    const address = formData.get('address')?.toString() || title;
    const price = formData.get('price')?.toString() || '';
    const status = formData.get('status')?.toString() || 'Available';
    const community = formData.get('community')?.toString() || '';
    const beds = parseInt(formData.get('beds')?.toString() || '0', 10);
    const baths = parseInt(formData.get('baths')?.toString() || '0', 10);
    const sqft = parseInt(formData.get('sqft')?.toString() || '0', 10);
    const image = formData.get('image')?.toString() || '';
    const description = formData.get('description')?.toString() || '';

    if (!title || !price) {
      error = 'Title and Price are required.';
    } else {
      await runtime.env.DB.prepare(`
        INSERT INTO inventory_homes 
        (title, address, price, status, community, beds, baths, sqft, image, description) 
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
      `).bind(title, address, price, status, community, beds, baths, sqft, image, description).run();
      
      return Astro.redirect('/admin/inventory/');
    }
  } catch (e) {
    console.error(e);
    error = 'Failed to save new home. Please try again.';
  }
}
---

<BaseLayout title="Add New Home | Inventory" noIndex={true}>
  <Container class="max-w-[800px] py-12">
    <div class="mb-8" data-ps="src/pages/admin/inventory/new.astro:apofb4">
      <a href="/admin/inventory/" class="text-primary hover:underline text-sm font-semibold mb-4 inline-block" data-ps="src/pages/admin/inventory/new.astro:waq1ya">← Back to Inventory</a>
      <h1 class="text-3xl font-bold font-serif" data-ps="src/pages/admin/inventory/new.astro:lezs95">Add New Home</h1>
    </div>

    {error && (
      <div class="bg-red-50 text-red-700 p-4 rounded-lg border border-red-200 mb-6" data-ps="src/pages/admin/inventory/new.astro:apofb3">
        {error}
      </div>
    )}

    <form method="POST" class="bg-surface rounded-[8px] border border-border p-8 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/pages/admin/inventory/new.astro:apofb2">
        <div data-ps="src/pages/admin/inventory/new.astro:apofb1">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j6k">Title *</label>
          <input type="text" name="title" required class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. 123 Main St - Model Home" />
        </div>
        <div data-ps="src/pages/admin/inventory/new.astro:apofb0">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j6j">Price *</label>
          <input type="text" name="price" required class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. $79,900" />
        </div>
        
        <div data-ps="src/pages/admin/inventory/new.astro:wf9l4s">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j6i">Address</label>
          <input type="text" name="address" class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. 123 Main St, Columbus, OH" />
        </div>
        <div data-ps="src/pages/admin/inventory/new.astro:wf9l4r">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j6h">Status</label>
          <select name="status" class="w-full px-4 py-2 border rounded-lg bg-white">
            <option value="Available">Available</option>
            <option value="New">New</option>
            <option value="Pending">Pending</option>
            <option value="Sold">Sold</option>
          </select>
        </div>

        <div data-ps="src/pages/admin/inventory/new.astro:wf9l4q">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j6g">Community</label>
          <input type="text" name="community" class="w-full px-4 py-2 border rounded-lg" placeholder="e.g. Big Run Bluffs" />
        </div>
        <div class="grid grid-cols-3 gap-4" data-ps="src/pages/admin/inventory/new.astro:wf9l4p">
          <div data-ps="src/pages/admin/inventory/new.astro:wf9l4o">
            <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j6f">Beds</label>
            <input type="number" name="beds" class="w-full px-4 py-2 border rounded-lg" placeholder="3" />
          </div>
          <div data-ps="src/pages/admin/inventory/new.astro:wf9l4n">
            <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j6e">Baths</label>
            <input type="number" name="baths" class="w-full px-4 py-2 border rounded-lg" placeholder="2" />
          </div>
          <div data-ps="src/pages/admin/inventory/new.astro:wf9l4m">
            <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j6d">Sq Ft</label>
            <input type="number" name="sqft" class="w-full px-4 py-2 border rounded-lg" placeholder="1200" />
          </div>
        </div>

        <div class="md:col-span-2" data-ps="src/pages/admin/inventory/new.astro:wf9l4l">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j5r">Main Image URL</label>
          <input type="url" name="image" class="w-full px-4 py-2 border rounded-lg" placeholder="https://cdn.pagesmith.app/..." />
        </div>

        <div class="md:col-span-2" data-ps="src/pages/admin/inventory/new.astro:wf9l4k">
          <label class="block text-sm font-medium mb-2" data-ps="src/pages/admin/inventory/new.astro:hm7j5q">Description</label>
          <textarea name="description" rows="5" class="w-full px-4 py-2 border rounded-lg" placeholder="Detailed description of the home..."></textarea>
        </div>
      </div>

      <div class="pt-4 border-t border-border flex justify-end" data-ps="src/pages/admin/inventory/new.astro:wf9l4j">
        <button type="submit" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-hover transition-colors" data-ps="src/pages/admin/inventory/new.astro:p96hhx">
          Save Home
        </button>
      </div>
    </form>
  </Container>
</BaseLayout>
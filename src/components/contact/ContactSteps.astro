---
import Container from '@/components/Container.astro';
---

<section id="what-next" class="bg-background py-[60px]">
  <Container class="max-w-[1000px]">
    <h2 class="text-[32px] font-serif font-semibold text-foreground text-center mb-12">What happens next?</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <div class="text-center">
        <div class="w-12 h-12 bg-primary text-primary-foreground rounded-full flex items-center justify-center mx-auto mb-4 text-[20px] font-bold">1</div>
        <h3 class="text-[18px] font-semibold text-foreground mb-2">Answer a few questions.</h3>
        <p class="text-[16px] text-muted-foreground">Tell us what you are looking for. It takes about 2 minutes.</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 bg-primary text-primary-foreground rounded-full flex items-center justify-center mx-auto mb-4 text-[20px] font-bold">2</div>
        <h3 class="text-[18px] font-semibold text-foreground mb-2">We match you with the right team member.</h3>
        <p class="text-[16px] text-muted-foreground">Sales, financing, community management — whoever can help you most.</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 bg-primary text-primary-foreground rounded-full flex items-center justify-center mx-auto mb-4 text-[20px] font-bold">3</div>
        <h3 class="text-[18px] font-semibold text-foreground mb-2">We reach out within one business day.</h3>
        <p class="text-[16px] text-muted-foreground">By phone, text, or email — whichever you prefer.</p>
      </div>
    </div>
  </Container>
</section>

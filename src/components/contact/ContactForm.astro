---
import Container from '@/components/Container.astro';
---

<section id="contact-form" class="bg-secondary py-[80px]">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Left side - Phone -->
      <div class="flex flex-col justify-center">
        <h2 class="text-[40px] font-serif font-semibold text-foreground mb-6">Prefer to call?</h2>
        <a href="tel:6144437421" class="text-[32px] font-semibold text-primary hover:text-primary-hover transition-colors mb-4">(614) 443-7421</a>
        <p class="text-[16px] text-muted-foreground">Monday–Friday, 9am–5pm</p>
      </div>

      <!-- Right side - Form -->
      <div class="bg-surface rounded-[8px] border border-border p-8">
        <p class="text-[12px] font-bold tracking-wider uppercase text-muted-foreground mb-2">Step 1 of 7</p>
        <h3 class="text-[24px] font-serif font-semibold text-foreground mb-6">What are you looking for today?</h3>

        <form class="space-y-4">
          <label class="flex items-start gap-3 p-4 border border-border rounded-[6px] cursor-pointer hover:border-primary transition-colors">
            <input type="radio" name="looking-for" value="pre-owned" class="mt-1 w-4 h-4 accent-primary" />
            <span class="text-[16px] text-foreground">I want to buy a pre-owned home</span>
          </label>

          <label class="flex items-start gap-3 p-4 border border-border rounded-[6px] cursor-pointer hover:border-primary transition-colors">
            <input type="radio" name="looking-for" value="new-home" class="mt-1 w-4 h-4 accent-primary" />
            <span class="text-[16px] text-foreground">I want to order a brand new home</span>
          </label>

          <label class="flex items-start gap-3 p-4 border border-border rounded-[6px] cursor-pointer hover:border-primary transition-colors">
            <input type="radio" name="looking-for" value="rent-lot" class="mt-1 w-4 h-4 accent-primary" />
            <span class="text-[16px] text-foreground">I want to rent a lot in one of your communities</span>
          </label>

          <label class="flex items-start gap-3 p-4 border border-border rounded-[6px] cursor-pointer hover:border-primary transition-colors">
            <input type="radio" name="looking-for" value="financing" class="mt-1 w-4 h-4 accent-primary" />
            <span class="text-[16px] text-foreground">I want to apply for financing</span>
          </label>

          <label class="flex items-start gap-3 p-4 border border-border rounded-[6px] cursor-pointer hover:border-primary transition-colors">
            <input type="radio" name="looking-for" value="resident" class="mt-1 w-4 h-4 accent-primary" />
            <span class="text-[16px] text-foreground">I am already a resident and need help</span>
          </label>

          <label class="flex items-start gap-3 p-4 border border-border rounded-[6px] cursor-pointer hover:border-primary transition-colors">
            <input type="radio" name="looking-for" value="unsure" class="mt-1 w-4 h-4 accent-primary" />
            <span class="text-[16px] text-foreground">I am not sure yet — help me figure it out</span>
          </label>

          <button
            type="submit"
            class="bg-muted-foreground/30 text-white rounded-[6px] px-[24px] py-[10px] text-[14px] font-semibold mt-6 w-full hover:bg-muted-foreground/50 transition-colors"
          >
            Continue
          </button>
        </form>
      </div>
    </div>
  </Container>
</section>

---
import Container from '@/components/Container.astro';
---

<section id="contact-hero" class="bg-dark py-[80px]">
  <Container class="max-w-[1200px]">
    <div class="max-w-[800px] mx-auto text-center">
      <p class="text-accent text-[12px] font-bold tracking-widest uppercase mb-4">GET IN TOUCH</p>
      <h1 class="text-[56px] font-serif font-semibold text-dark-foreground leading-[1.1] mb-6">
        We are here to help.
      </h1>
      <p class="text-[20px] text-dark-muted leading-relaxed">
        Whether you are buying, renting a lot, applying for financing, or already a resident — our team is ready to help you with the next step.
      </p>
    </div>
  </Container>
</section>

<section id="contact-info" class="bg-background py-[60px]">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div>
        <p class="text-[12px] font-bold tracking-wider uppercase text-muted-foreground mb-2">Main Line</p>
        <a href="tel:6144437421" class="text-[20px] font-semibold text-foreground hover:text-primary transition-colors">(614) 443-7421</a>
      </div>
      <div>
        <p class="text-[12px] font-bold tracking-wider uppercase text-muted-foreground mb-2">Office Hours</p>
        <p class="text-[20px] font-semibold text-foreground">Monday–Friday, 9am–5pm</p>
      </div>
      <div>
        <p class="text-[12px] font-bold tracking-wider uppercase text-muted-foreground mb-2">Based in</p>
        <p class="text-[20px] font-semibold text-foreground">Central Ohio</p>
      </div>
    </div>
  </Container>
</section>

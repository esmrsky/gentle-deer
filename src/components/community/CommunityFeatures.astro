---
interface Props {
  community: {
    name: string;
    address: string;
    phone: string;
    phoneRaw: string;
    officeHours: string;
    features: Array<{ title: string; description: string }>;
    homesCount: number;
  };
}

const { community } = Astro.props;
---

<section class="bg-surface py-16 md:py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16">
      <div>
        <h3 class="text-[12px] font-bold tracking-widest text-accent uppercase mb-6">What you get here.</h3>
        <div class="grid grid-cols-2 gap-6">
          {community.features.map((feature) => (
            <div>
              <h4 class="text-[16px] font-semibold text-foreground mb-2">{feature.title}</h4>
              <p class="text-[14px] text-muted-foreground leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-[12px] font-bold tracking-widest text-accent uppercase mb-6">Community Details</h3>
        <div class="bg-background rounded-[8px] p-6 space-y-5">
          <div>
            <span class="text-[11px] font-semibold tracking-wider text-muted-foreground uppercase block mb-1">Address</span>
            <span class="text-[15px] text-foreground">{community.address}</span>
          </div>
          <div>
            <span class="text-[11px] font-semibold tracking-wider text-muted-foreground uppercase block mb-1">Phone</span>
            <a href={`tel:${community.phoneRaw}`} class="text-[15px] text-primary hover:underline">{community.phone}</a>
          </div>
          <div>
            <span class="text-[11px] font-semibold tracking-wider text-muted-foreground uppercase block mb-1">Office Hours</span>
            <span class="text-[15px] text-foreground">{community.officeHours}</span>
          </div>
          <div>
            <span class="text-[11px] font-semibold tracking-wider text-muted-foreground uppercase block mb-1">Community Manager</span>
            <span class="text-[15px] text-foreground">[TBD Manager Name]</span>
          </div>
          <div>
            <span class="text-[11px] font-semibold tracking-wider text-muted-foreground uppercase block mb-1">Homes Available</span>
            <span class="text-[15px] text-foreground">{community.homesCount} available now</span>
          </div>
          <a
            href={`tel:${community.phoneRaw}`}
            class="inline-block bg-primary text-primary-foreground rounded-[6px] px-[20px] py-[10px] text-[14px] font-semibold no-underline hover:bg-primary-hover transition-colors mt-4"
          >
            Check Availability
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

---
interface RelatedCommunity {
  label: string;
  name: string;
  location: string;
  url: string;
}

interface Props {
  communities: RelatedCommunity[];
}

const { communities } = Astro.props;
---

<section class="bg-background py-16 md:py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <h3 class="text-[12px] font-bold tracking-widest text-accent uppercase mb-8">
      Explore other communities.
    </h3>

    <div class="grid md:grid-cols-3 gap-6">
      {communities.map((community) => (
        <a href={community.url} class="card group hover:-translate-y-0.5 hover:shadow-md transition-all no-underline p-0">
          <div class="bg-secondary p-6">
            <span class="text-[10px] font-bold tracking-widest text-accent uppercase block mb-2">
              {community.label}
            </span>
            <h4 class="text-[18px] font-semibold text-foreground mb-1 group-hover:text-primary transition-colors">
              {community.name}
            </h4>
            <p class="text-[14px] text-muted-foreground mb-4">{community.location}</p>
            <span class="text-[14px] text-primary font-semibold group-hover:underline">
              See availability →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

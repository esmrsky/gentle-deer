---
import Container from '@/components/Container.astro';
---

<section id="filters" class="bg-surface border-b border-border py-6 sticky top-[76px] z-30" data-ps="src/components/shophomes/ShopHomesFilters.astro:6450pt">
  <Container class="max-w-[1200px]">
    <div class="flex flex-wrap gap-3 items-center" data-ps="src/components/shophomes/ShopHomesFilters.astro:6jsj08">
      <!-- Price -->
      <select id="filter-price" class="bg-background border border-border rounded-[6px] px-4 py-2 text-[14px] text-foreground focus:outline-none focus:border-primary filter-control">
        <option>Any Price</option>
        <option>Under $30k</option>
        <option>$30k–$50k</option>
        <option>$50k–$75k</option>
        <option>$75k–$100k</option>
        <option>$100k+</option>
      </select>

      <!-- Beds -->
      <select id="filter-beds" class="bg-background border border-border rounded-[6px] px-4 py-2 text-[14px] text-foreground focus:outline-none focus:border-primary filter-control">
        <option>Any Beds</option>
        <option>1+</option>
        <option>2+</option>
        <option>3+</option>
        <option>4+</option>
      </select>

      <!-- Baths -->
      <select id="filter-baths" class="bg-background border border-border rounded-[6px] px-4 py-2 text-[14px] text-foreground focus:outline-none focus:border-primary filter-control">
        <option>Any Baths</option>
        <option>1+</option>
        <option>2+</option>
        <option>3+</option>
      </select>

      <!-- Community -->
      <select id="filter-community" class="bg-background border border-border rounded-[6px] px-4 py-2 text-[14px] text-foreground focus:outline-none focus:border-primary filter-control">
        <option>Any Community</option>
        <option>Big Run Bluffs</option>
        <option>Enchanted Acres</option>
        <option>Parsons Mobile Home Park</option>
        <option>Casal Court</option>
        <option>Foxlair Farms</option>
        <option>Buckeye Lake Estates</option>
        <option>Willowbrook Terrace</option>
        <option>Washington Manor</option>
        <option>Wagon Wheel</option>
      </select>

      <!-- Condition -->
      <select id="filter-condition" class="bg-background border border-border rounded-[6px] px-4 py-2 text-[14px] text-foreground focus:outline-none focus:border-primary filter-control">
        <option>Any Condition</option>
        <option>Pre-Owned</option>
        <option>New</option>
      </select>

      <!-- Sort -->
      <select id="sort-homes" class="bg-background border border-border rounded-[6px] px-4 py-2 text-[14px] text-foreground focus:outline-none focus:border-primary ml-auto filter-control">
        <option>Price: Low to High</option>
        <option>Price: High to Low</option>
      </select>

      <!-- Reset -->
      <button id="reset-filters" class="text-[14px] text-muted-foreground hover:text-foreground transition-colors" data-ps="src/components/shophomes/ShopHomesFilters.astro:jvdnv6">
        Reset
      </button>
    </div>
  </Container>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const controls = document.querySelectorAll('.filter-control');
    const resetButton = document.getElementById('reset-filters');

    controls.forEach(ctrl => {
      ctrl.addEventListener('change', () => {
        if (window.updateShopHomesFilters) {
          window.updateShopHomesFilters();
        }
      });
    });

    if (resetButton) {
      resetButton.addEventListener('click', () => {
        controls.forEach(ctrl => {
          ctrl.value = ctrl.options[0].value; // Reset to first option
        });
        if (window.updateShopHomesFilters) {
          window.updateShopHomesFilters();
        }
      });
    }
  });
</script>
    </div>
  </Container>
</section>

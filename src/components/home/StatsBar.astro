---
import Container from '@/components/Container.astro';
---

<section id="stats" class="bg-primary py-[60px]" data-ps="src/components/home/StatsBar.astro:stats-gl">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-ps="src/components/home/StatsBar.astro:tldr3e">
      <div class="flex flex-col items-center" data-ps="src/components/home/StatsBar.astro:tldr3f">
        <span class="text-[40px] font-semibold text-white font-serif mb-1" data-ps="src/components/home/StatsBar.astro:8bm6ft">40+</span>
        <span class="text-[12px] uppercase tracking-widest font-bold text-white/80" data-ps="src/components/home/StatsBar.astro:8bm6fu">Years Serving Central Ohio</span>
      </div>
      <div class="flex flex-col items-center border-l border-white/20 md:border-l-0" data-ps="src/components/home/StatsBar.astro:tldr3g">
        <span class="text-[40px] font-semibold text-white font-serif mb-1" data-ps="src/components/home/StatsBar.astro:8bm6fv">9</span>
        <span class="text-[12px] uppercase tracking-widest font-bold text-white/80" data-ps="src/components/home/StatsBar.astro:4un1hp">Communities Operated</span>
      </div>
      <div class="flex flex-col items-center md:border-l border-white/20" data-ps="src/components/home/StatsBar.astro:tldr3h">
        <span class="text-[40px] font-semibold text-white font-serif mb-1" data-ps="src/components/home/StatsBar.astro:4un1hq">2,000+</span>
        <span class="text-[12px] uppercase tracking-widest font-bold text-white/80" data-ps="src/components/home/StatsBar.astro:4un1hr">Houses Built</span>
      </div>
      <div class="flex flex-col items-center border-l border-white/20" data-ps="src/components/home/StatsBar.astro:tldr3i">
        <span class="text-[40px] font-semibold text-white font-serif mb-1" data-ps="src/components/home/StatsBar.astro:4un1hs">FAMILY-RUN</span>
        <span class="text-[12px] uppercase tracking-widest font-bold text-white/80" data-ps="src/components/home/StatsBar.astro:4un1ht">Since Day One</span>
      </div>
    </div>
  </Container>
</section>

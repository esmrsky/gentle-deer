---
import Container from '@/components/Container.astro';
---

<section id="team" class="bg-background py-[80px]" data-ps="src/components/home/Team.astro:team-gl">
  <Container class="max-w-[1200px]">
    <div class="text-center mb-12" data-ps="src/components/home/Team.astro:1zptku">
      <h2 class="text-[32px] font-semibold text-foreground mb-4" data-ps="src/components/home/Team.astro:maqv6r">Meet the Greenlawn family.</h2>
      <p class="text-[16px] text-muted-foreground" data-ps="src/components/home/Team.astro:aderva">Real people, real roots, here when you need us.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/home/Team.astro:1zptkv">
      <!-- Member 1 -->
      <div class="bg-surface rounded-[8px] border border-border p-8 text-center flex flex-col items-center card-hover transition-all" data-ps="src/components/home/Team.astro:1zptkw">
        <div class="w-[100px] h-[100px] rounded-full bg-secondary mb-6 overflow-hidden" data-ps="src/components/home/Team.astro:1zptkx">
          <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=200&auto=format&fit=crop" alt="Leadership Name" class="w-full h-full object-cover" crossorigin="anonymous" data-ps="src/components/home/Team.astro:bs4p8w" />
        </div>
        <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/Team.astro:7mbxz4">[Leadership Name]</h3>
        <p class="text-[14px] text-muted-foreground uppercase font-bold tracking-wider mb-4" data-ps="src/components/home/Team.astro:aderv9">Owner</p>
        <p class="text-[14px] text-muted-foreground leading-relaxed" data-ps="src/components/home/Team.astro:aderun">
          Third-generation Central Ohio native, runs the family business with his wife and kids.
        </p>
      </div>

      <!-- Member 2 -->
      <div class="bg-surface rounded-[8px] border border-border p-8 text-center flex flex-col items-center card-hover transition-all" data-ps="src/components/home/Team.astro:1zptky">
        <div class="w-[100px] h-[100px] rounded-full bg-secondary mb-6 overflow-hidden" data-ps="src/components/home/Team.astro:1zptkz">
          <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=200&auto=format&fit=crop" alt="Leadership Name" class="w-full h-full object-cover" crossorigin="anonymous" data-ps="src/components/home/Team.astro:rvj52g" />
        </div>
        <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/Team.astro:7mbxz5">[Leadership Name]</h3>
        <p class="text-[14px] text-muted-foreground uppercase font-bold tracking-wider mb-4" data-ps="src/components/home/Team.astro:aderum">General Manager</p>
        <p class="text-[14px] text-muted-foreground leading-relaxed" data-ps="src/components/home/Team.astro:aderul">
          Has been helping families find their home with Greenlawn for over 15 years.
        </p>
      </div>

      <!-- Member 3 -->
      <div class="bg-surface rounded-[8px] border border-border p-8 text-center flex flex-col items-center card-hover transition-all" data-ps="src/components/home/Team.astro:1zptl0">
        <div class="w-[100px] h-[100px] rounded-full bg-secondary mb-6 overflow-hidden" data-ps="src/components/home/Team.astro:1zptl1">
          <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=200&auto=format&fit=crop" alt="Leadership Name" class="w-full h-full object-cover" crossorigin="anonymous" data-ps="src/components/home/Team.astro:rvj52f" />
        </div>
        <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/Team.astro:7mbxz6">[Leadership Name]</h3>
        <p class="text-[14px] text-muted-foreground uppercase font-bold tracking-wider mb-4" data-ps="src/components/home/Team.astro:aderuk">Community Operations</p>
        <p class="text-[14px] text-muted-foreground leading-relaxed" data-ps="src/components/home/Team.astro:aderuj">
          Oversees all 9 Greenlawn communities and makes sure residents are taken care of.
        </p>
      </div>
    </div>
  </Container>
</section>

---
import Container from '@/components/Container.astro';
---

<section id="story" class="bg-background py-[80px]" data-ps="src/components/home/Story.astro:story-gl">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center" data-ps="src/components/home/Story.astro:ptu7se">
      <div class="reveal-left order-2 md:order-1" data-ps="src/components/home/Story.astro:ptu7sf">
        <img 
          src="https://cdn.pagesmith.app/69b93246/images/judhpwyXPDYlhlaH-1536.webp" 
          alt="Greenlawn Family Business" 
          class="w-full aspect-[16/10] object-cover rounded-[8px] shadow-lg" data-ps="src/components/home/Story.astro:41equv" />
      </div>
      <div class="reveal-right order-1 md:order-2" data-ps="src/components/home/Story.astro:ptu7sg">
        <h2 class="text-[32px] font-semibold text-foreground leading-tight mb-6" data-ps="src/components/home/Story.astro:gp6j3g">A family business, built for families.</h2>
        <div class="space-y-4 text-[18px] text-foreground/80 leading-relaxed mb-8" data-ps="src/components/home/Story.astro:ptu7sh">
          <p data-ps="src/components/home/Story.astro:8vnld8">
            Greenlawn started as a family operation and still runs that way. We take pride in knowing our residents, standing behind what we sell, and building communities people want to stay in.
          </p>
          <p data-ps="src/components/home/Story.astro:8vnld9">
            When you call us, you talk to someone who lives this work.
          </p>
        </div>
        <a href="/our-story" class="text-primary font-bold hover:underline" data-ps="src/components/home/Story.astro:93wte1">Read our full story</a>
      </div>
    </div>
  </Container>
</section>

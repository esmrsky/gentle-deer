---
import Container from '@/components/Container.astro';
---

<section id="features-icons" class="bg-background py-[80px]" data-ps="src/components/home/FeaturesIcons.astro:features-gl">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12" data-ps="src/components/home/FeaturesIcons.astro:1bor2b">
      <!-- Feature 1 -->
      <div class="flex flex-col gap-4" data-ps="src/components/home/FeaturesIcons.astro:1bor2c">
        <div class="text-primary" data-ps="src/components/home/FeaturesIcons.astro:1bor2d">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-home"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3 class="text-[20px] font-semibold text-foreground" data-ps="src/components/home/FeaturesIcons.astro:nrypa0">New & Pre-Owned Homes</h3>
        <p class="text-[16px] text-muted-foreground leading-relaxed" data-ps="src/components/home/FeaturesIcons.astro:tvhgck">
          Browse our full inventory of move-in ready and custom-order manufactured homes across Central Ohio.
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="flex flex-col gap-4" data-ps="src/components/home/FeaturesIcons.astro:1bor2e">
        <div class="text-primary" data-ps="src/components/home/FeaturesIcons.astro:1bor2f">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="text-[20px] font-semibold text-foreground" data-ps="src/components/home/FeaturesIcons.astro:nryp9z">9 Communities</h3>
        <p class="text-[16px] text-muted-foreground leading-relaxed" data-ps="src/components/home/FeaturesIcons.astro:tvhgcl">
          From Central Ohio neighborhoods to lakeside retreats, we own and operate nine communities for every lifestyle and life stage.
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="flex flex-col gap-4" data-ps="src/components/home/FeaturesIcons.astro:1bor2g">
        <div class="text-primary" data-ps="src/components/home/FeaturesIcons.astro:1bor2h">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-[20px] font-semibold text-foreground" data-ps="src/components/home/FeaturesIcons.astro:nryp9y">Family-Run Since Day One</h3>
        <p class="text-[16px] text-muted-foreground leading-relaxed" data-ps="src/components/home/FeaturesIcons.astro:tvhgcm">
          We take pride in knowing our residents by name and standing behind every home we sell.
        </p>
      </div>
    </div>
  </Container>
</section>

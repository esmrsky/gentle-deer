---
import Container from '@/components/Container.astro';
---

<section id="resident" class="bg-background py-[60px]" data-ps="src/components/home/Resident.astro:res-gl">
  <Container class="max-w-[600px] text-center">
    <h2 class="text-[32px] font-semibold text-foreground mb-4" data-ps="src/components/home/Resident.astro:injm7u">Already a Greenlawn resident?</h2>
    <p class="text-[16px] text-muted-foreground" data-ps="src/components/home/Resident.astro:r5j71p">Find your community page to pay rent, submit a maintenance request, or reach your on-site manager.</p>
    <a href="/communities" class="bg-primary text-primary-foreground font-semibold py-3 px-8 rounded-[6px] hover:bg-primary-hover transition-colors inline-block no-underline mt-8" data-ps="src/components/home/Resident.astro:qx9z0w">
      Find My Community
    </a>
  </Container>
</section>

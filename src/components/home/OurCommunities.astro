---
import Container from '@/components/Container.astro';
import { getCollection } from 'astro:content';

const runtime = Astro.locals.runtime;
let dbCommunities: any[] = [];

if (runtime?.env?.DB) {
  try {
    const { results } = await runtime.env.DB.prepare('SELECT * FROM communities ORDER BY created_at DESC LIMIT 6').all();
    dbCommunities = results;
  } catch (e) {
    console.error('Failed to fetch DB communities:', e);
  }
}

const mdCommunities = await getCollection('communities');
const allCommunities = [
  ...dbCommunities.map(c => ({
    label: c.badge || 'COMMUNITY',
    name: c.title,
    location: c.location,
    image: c.hero_image,
    url: `/communities/${c.id}`
  })),
  ...mdCommunities.map(c => ({
    label: c.data.badge || 'COMMUNITY',
    name: c.data.title,
    location: c.data.location,
    image: c.data.heroImage,
    url: `/communities/${c.slug}`
  }))
].slice(0, 6); // Take top 6
---

<section id="our-communities" class="bg-background py-[80px]" data-ps="src/components/home/OurCommunities.astro:comm-gl">
  <Container class="max-w-[1200px]">
    <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4" data-ps="src/components/home/OurCommunities.astro:hlzlrf">
      <h2 class="text-[40px] font-semibold text-foreground leading-tight" data-ps="src/components/home/OurCommunities.astro:9wq2rg">Our communities.</h2>
      <a href="/communities" class="text-primary font-semibold hover:underline" data-ps="src/components/home/OurCommunities.astro:f8zvbv">See All Communities</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/home/OurCommunities.astro:hlzls1">
      {allCommunities.map(community => (
        <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/OurCommunities.astro:qxecu3">
          <div class="relative aspect-video overflow-hidden bg-muted" data-ps="src/components/home/OurCommunities.astro:qxecu2">
             {community.image && (
               <img src={community.image} alt={community.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-ps="src/components/home/OurCommunities.astro:e8gqhs" />
             )}
             <span class="absolute top-3 left-3 bg-black/60 text-white px-2.5 py-1 text-[10px] uppercase font-bold rounded-[2px] tracking-wider" data-ps="src/components/home/OurCommunities.astro:q5g2lk">{community.label}</span>
          </div>
          <div class="p-6" data-ps="src/components/home/OurCommunities.astro:qxecu1">
            <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/OurCommunities.astro:9bhkz9">{community.name}</h3>
            <p class="text-[14px] text-muted-foreground mb-4" data-ps="src/components/home/OurCommunities.astro:s7tda4">{community.location}</p>
            <a href={community.url} class="text-primary text-[14px] font-bold flex items-center gap-1 hover:gap-2 transition-all" data-ps="src/components/home/OurCommunities.astro:rzk59d">
              See availability <span class="text-lg" data-ps="src/components/home/OurCommunities.astro:q5g2ll">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center" data-ps="src/components/home/OurCommunities.astro:qxecu1">
      <a href="/communities" class="bg-primary text-primary-foreground font-semibold py-3 px-10 rounded-[6px] hover:bg-primary-hover transition-colors inline-block no-underline" data-ps="src/components/home/OurCommunities.astro:f8zvbo">
        See All Communities
      </a>
    </div>
  </Container>
</section>

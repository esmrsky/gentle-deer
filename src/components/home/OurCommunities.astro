---
import Container from '@/components/Container.astro';
---

<section id="our-communities" class="bg-background py-[80px]" data-ps="src/components/home/OurCommunities.astro:comm-gl">
  <Container class="max-w-[1200px]">
    <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4" data-ps="src/components/home/OurCommunities.astro:hlzlrf">
      <h2 class="text-[40px] font-semibold text-foreground leading-tight" data-ps="src/components/home/OurCommunities.astro:9wq2rg">Our communities.</h2>
      <a href="/communities" class="text-primary font-semibold hover:underline" data-ps="src/components/home/OurCommunities.astro:f8zvbv">See All Communities</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/home/OurCommunities.astro:hlzls1">
      <!-- Community 1 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/OurCommunities.astro:hlzls2">
        <div class="relative aspect-video overflow-hidden bg-muted" data-ps="src/components/home/OurCommunities.astro:hlzls3">
           <img src="https://images.unsplash.com/photo-1590274853856-f22d5ee3d228?q=80&w=2000&auto=format&fit=crop" alt="Big Run Bluffs" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" crossorigin="anonymous" data-ps="src/components/home/OurCommunities.astro:f3qhft" />
           <span class="absolute top-3 left-3 bg-black/60 text-white px-2.5 py-1 text-[10px] uppercase font-bold rounded-[2px] tracking-wider" data-ps="src/components/home/OurCommunities.astro:tclmud">Affordable Living</span>
        </div>
        <div class="p-6" data-ps="src/components/home/OurCommunities.astro:hlzls4">
          <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/OurCommunities.astro:4rougv">Big Run Bluffs</h3>
          <p class="text-[14px] text-muted-foreground mb-4" data-ps="src/components/home/OurCommunities.astro:mcxrzz">Central Ohio</p>
          <a href="/communities/big-run-bluffs" class="text-primary text-[14px] font-bold flex items-center gap-1 hover:gap-2 transition-all" data-ps="src/components/home/OurCommunities.astro:f8zvbu">
            See availability <span class="text-lg" data-ps="src/components/home/OurCommunities.astro:tclmue">→</span>
          </a>
        </div>
      </div>

      <!-- Community 2 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/OurCommunities.astro:hlzls5">
        <div class="relative aspect-video overflow-hidden bg-muted" data-ps="src/components/home/OurCommunities.astro:hlzls6">
           <img src="https://cdn.pagesmith.app/69b93246/images/IPxGtbkztdCCaSUI-1536.webp" alt="Enchanted Acres" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-ps="src/components/home/OurCommunities.astro:f3qhfu" />
           <span class="absolute top-3 left-3 bg-black/60 text-white px-2.5 py-1 text-[10px] uppercase font-bold rounded-[2px] tracking-wider" data-ps="src/components/home/OurCommunities.astro:tclmv0">55+ Community</span>
        </div>
        <div class="p-6" data-ps="src/components/home/OurCommunities.astro:hlzls7">
          <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/OurCommunities.astro:4rougu">Enchanted Acres</h3>
          <p class="text-[14px] text-muted-foreground mb-4" data-ps="src/components/home/OurCommunities.astro:mcxrzy">Central Ohio</p>
          <a href="/communities/enchanted-acres" class="text-primary text-[14px] font-bold flex items-center gap-1 hover:gap-2 transition-all" data-ps="src/components/home/OurCommunities.astro:f8zvbt">
            See availability <span class="text-lg" data-ps="src/components/home/OurCommunities.astro:tclmv1">→</span>
          </a>
        </div>
      </div>

      <!-- Community 3 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/OurCommunities.astro:hlzls8">
        <div class="relative aspect-video overflow-hidden bg-muted" data-ps="src/components/home/OurCommunities.astro:hlzls9">
           <img src="https://images.pexels.com/photos/30503369/pexels-photo-30503369.jpeg?q=80&w=2000&auto=format&fit=crop" alt="Parsons Mobile Home Park" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" crossorigin="anonymous" data-ps="src/components/home/OurCommunities.astro:f3qhfv" />
           <span class="absolute top-3 left-3 bg-black/60 text-white px-2.5 py-1 text-[10px] uppercase font-bold rounded-[2px] tracking-wider" data-ps="src/components/home/OurCommunities.astro:tclmv2">Established Neighborhood</span>
        </div>
        <div class="p-6" data-ps="src/components/home/OurCommunities.astro:hlzlsa">
          <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/OurCommunities.astro:4rougt">Parsons Mobile Home Park</h3>
          <p class="text-[14px] text-muted-foreground mb-4" data-ps="src/components/home/OurCommunities.astro:mcxrzx">Central Ohio</p>
          <a href="/communities/parsons-mobile-home-park" class="text-primary text-[14px] font-bold flex items-center gap-1 hover:gap-2 transition-all" data-ps="src/components/home/OurCommunities.astro:f8zvbs">
            See availability <span class="text-lg" data-ps="src/components/home/OurCommunities.astro:tclmv3">→</span>
          </a>
        </div>
      </div>

      <!-- Community 4 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/OurCommunities.astro:qxecua">
        <div class="relative aspect-video overflow-hidden bg-muted" data-ps="src/components/home/OurCommunities.astro:qxecu9">
           <img src="https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?q=80&w=2000&auto=format&fit=crop" alt="Casal Court" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" crossorigin="anonymous" data-ps="src/components/home/OurCommunities.astro:f3qhfw" />
           <span class="absolute top-3 left-3 bg-black/60 text-white px-2.5 py-1 text-[10px] uppercase font-bold rounded-[2px] tracking-wider" data-ps="src/components/home/OurCommunities.astro:tclmv4">Quiet Streets</span>
        </div>
        <div class="p-6" data-ps="src/components/home/OurCommunities.astro:qxecu8">
          <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/OurCommunities.astro:4rougs">Casal Court</h3>
          <p class="text-[14px] text-muted-foreground mb-4" data-ps="src/components/home/OurCommunities.astro:mcxrzw">Central Ohio</p>
          <a href="/communities/casal-court" class="text-primary text-[14px] font-bold flex items-center gap-1 hover:gap-2 transition-all" data-ps="src/components/home/OurCommunities.astro:f8zvbr">
            See availability <span class="text-lg" data-ps="src/components/home/OurCommunities.astro:tclmv5">→</span>
          </a>
        </div>
      </div>

      <!-- Community 5 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/OurCommunities.astro:qxecu7">
        <div class="relative aspect-video overflow-hidden bg-muted" data-ps="src/components/home/OurCommunities.astro:qxecu6">
           <img src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?q=80&w=2000&auto=format&fit=crop" alt="Foxlair Farms" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" crossorigin="anonymous" data-ps="src/components/home/OurCommunities.astro:f3qhfx" />
           <span class="absolute top-3 left-3 bg-black/60 text-white px-2.5 py-1 text-[10px] uppercase font-bold rounded-[2px] tracking-wider" data-ps="src/components/home/OurCommunities.astro:tclmv6">Country Living</span>
        </div>
        <div class="p-6" data-ps="src/components/home/OurCommunities.astro:qxecu5">
          <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/OurCommunities.astro:4roug6">Foxlair Farms</h3>
          <p class="text-[14px] text-muted-foreground mb-4" data-ps="src/components/home/OurCommunities.astro:mcxrzv">Orient, Ohio</p>
          <a href="/communities/foxlair-farms" class="text-primary text-[14px] font-bold flex items-center gap-1 hover:gap-2 transition-all" data-ps="src/components/home/OurCommunities.astro:f8zvbq">
            See availability <span class="text-lg" data-ps="src/components/home/OurCommunities.astro:tclmv7">→</span>
          </a>
        </div>
      </div>

      <!-- Community 6 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/OurCommunities.astro:qxecu4">
        <div class="relative aspect-video overflow-hidden bg-muted" data-ps="src/components/home/OurCommunities.astro:qxecu3">
           <img src="https://cdn.pagesmith.app/69b93246/images/KlsQvzdVYvCLZFHi-1536.webp" alt="Buckeye Lake Estates" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-ps="src/components/home/OurCommunities.astro:f3qhfy" />
           <span class="absolute top-3 left-3 bg-black/60 text-white px-2.5 py-1 text-[10px] uppercase font-bold rounded-[2px] tracking-wider" data-ps="src/components/home/OurCommunities.astro:tclmv8">Young Families</span>
        </div>
        <div class="p-6" data-ps="src/components/home/OurCommunities.astro:qxecu2">
          <h3 class="text-[20px] font-semibold text-foreground mb-1" data-ps="src/components/home/OurCommunities.astro:4roug5">Buckeye Lake Estates</h3>
          <p class="text-[14px] text-muted-foreground mb-4" data-ps="src/components/home/OurCommunities.astro:mcxrzu">Buckeye Lake, Ohio</p>
          <a href="/communities/buckeye-lake-estates" class="text-primary text-[14px] font-bold flex items-center gap-1 hover:gap-2 transition-all" data-ps="src/components/home/OurCommunities.astro:f8zvbp">
            See availability <span class="text-lg" data-ps="src/components/home/OurCommunities.astro:tclmv9">→</span>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center" data-ps="src/components/home/OurCommunities.astro:qxecu1">
      <a href="/communities" class="bg-primary text-primary-foreground font-semibold py-3 px-10 rounded-[6px] hover:bg-primary-hover transition-colors inline-block no-underline" data-ps="src/components/home/OurCommunities.astro:f8zvbo">
        See All Communities
      </a>
    </div>
  </Container>
</section>

---
import Container from '@/components/Container.astro';
---

<section id="contact" class="bg-background py-[80px] pb-[120px]" data-ps="src/components/home/Contact.astro:contact-gl">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center" data-ps="src/components/home/Contact.astro:1ijz25">
      <div data-ps="src/components/home/Contact.astro:1ijz26">
        <h2 class="text-[40px] font-semibold text-foreground mb-10" data-ps="src/components/home/Contact.astro:hp7u2r">Come see us.</h2>
        <div class="space-y-6" data-ps="src/components/home/Contact.astro:1ijz27">
          <div class="flex items-center gap-4" data-ps="src/components/home/Contact.astro:1ijz28">
            <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center text-secondary-foreground" data-ps="src/components/home/Contact.astro:1ijz29">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <span class="text-[16px] font-medium text-foreground" data-ps="src/components/home/Contact.astro:jamzsw">Monday through Friday, 9am to 5pm</span>
          </div>
          <div class="flex items-center gap-4" data-ps="src/components/home/Contact.astro:1ijz2a">
            <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center text-secondary-foreground" data-ps="src/components/home/Contact.astro:1ijz2b">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <a href="tel:6144437421" class="text-[16px] font-medium text-foreground hover:text-primary transition-colors" data-ps="src/components/home/Contact.astro:xsl4xm">(614) 443-7421</a>
          </div>
          <div class="flex items-center gap-4" data-ps="src/components/home/Contact.astro:1ijz2c">
            <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center text-secondary-foreground" data-ps="src/components/home/Contact.astro:1ijz2d">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <span class="text-[16px] font-medium text-foreground" data-ps="src/components/home/Contact.astro:jamzsv">Based in Central Ohio</span>
          </div>
        </div>
      </div>

      <div class="bg-surface p-8 rounded-[8px] border border-border" data-ps="src/components/home/Contact.astro:1ijz2e">
        <p class="text-[18px] text-foreground leading-relaxed mb-8" data-ps="src/components/home/Contact.astro:u4l0bs">
          Have a specific question? Use our smart questionnaire to get matched with the right team member.
        </p>
        <a href="/contact" class="bg-primary text-primary-foreground font-semibold py-4 px-8 rounded-[6px] hover:bg-primary-hover transition-colors inline-block no-underline" data-ps="src/components/home/Contact.astro:xsl4xl">
          Get in Touch
        </a>
      </div>
    </div>
  </Container>
</section>

        </div>
      </div>

      <!-- Home 6 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/AvailableHomes.astro:l7th9t">
        <div class="relative aspect-video overflow-hidden" data-ps="src/components/home/AvailableHomes.astro:l7th9u">
          <img src="https://cdn.pagesmith.app/69b93246/images/EEeRzEtYqjOxEmEs-1536.webp" alt="Casal Court home" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-ps="src/components/home/AvailableHomes.astro:fy49cx" />
          <span class="absolute top-0 right-0 bg-accent text-accent-foreground px-3 py-1 text-[11px] uppercase font-bold rounded-bl-[4px]" data-ps="src/components/home/AvailableHomes.astro:byzkfm">Pre-Owned</span>
        </div>
        <div class="p-5" data-ps="src/components/home/AvailableHomes.astro:l7th9v">
          <div class="text-[24px] font-semibold text-foreground mb-1" data-ps="src/components/home/AvailableHomes.astro:l7th9w">$71,800</div>
          <div class="text-[14px] text-muted-foreground mb-3 font-medium" data-ps="src/components/home/AvailableHomes.astro:l7th9x">3 bed — 1 bath — 1,152 sqft</div>
          <div class="text-[14px] text-foreground font-semibold mb-4" data-ps="src/components/home/AvailableHomes.astro:l7th9y">Casal Court</div>

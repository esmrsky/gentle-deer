          <span class="absolute top-0 right-0 bg-accent text-accent-foreground px-3 py-1 text-[11px] uppercase font-bold rounded-bl-[4px]" data-ps="src/components/home/AvailableHomes.astro:byzkfo">Pre-Owned</span>
        </div>
        <div class="p-5" data-ps="src/components/home/AvailableHomes.astro:igddqs">
          <div class="text-[24px] font-semibold text-foreground mb-1" data-ps="src/components/home/AvailableHomes.astro:igddqt">$56,200</div>
          <div class="text-[14px] text-muted-foreground mb-3 font-medium" data-ps="src/components/home/AvailableHomes.astro:igddqu">2 bed — 2 bath — 1,040 sqft</div>

---
import Container from '@/components/Container.astro';
import { getCollection } from 'astro:content';

const runtime = Astro.locals.runtime;
let dbHomes: any[] = [];

if (runtime?.env?.DB) {
  try {
    const { results } = await runtime.env.DB.prepare('SELECT * FROM inventory_homes ORDER BY created_at DESC LIMIT 6').all();
    dbHomes = results;
  } catch (e) {
    console.error('Failed to fetch DB inventory:', e);
  }
}

const mdHomes = await getCollection('homes');
const allHomes = [
  ...dbHomes.map(h => ({
    id: h.id,
    slug: h.id,
    data: {
      title: h.title,
      status: h.status,
      price: h.price,
      address: h.address,
      community: h.community,
      beds: h.beds,
      baths: h.baths,
      sqft: h.sqft,
      image: h.image
    }
  })),
  ...mdHomes
].slice(0, 6); // Take top 6
---

<section id="available-homes" class="bg-background py-[80px]" data-ps="src/components/home/AvailableHomes.astro:homes-gl">
  <Container class="max-w-[1200px]">
    <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4" data-ps="src/components/home/AvailableHomes.astro:igddoz">
      <div data-ps="src/components/home/AvailableHomes.astro:igddp0">
        <h2 class="text-[40px] font-semibold text-foreground leading-tight" data-ps="src/components/home/AvailableHomes.astro:yd45pt">Available Homes</h2>
      </div>
      <a href="/shop-homes" class="text-primary font-semibold hover:underline" data-ps="src/components/home/AvailableHomes.astro:grvezl">See All Homes</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/home/AvailableHomes.astro:igddp1">
      {allHomes.map(home => (
        <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/AvailableHomes.astro:l7th9u">
          <div class="relative aspect-video overflow-hidden" data-ps="src/components/home/AvailableHomes.astro:l7th9v">
            {home.data.image && (
              <img src={home.data.image} alt={home.data.title || "Home"} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-ps="src/components/home/AvailableHomes.astro:8nfhdf" />
            )}
            {home.data.status && (
              <span class={`absolute top-0 right-0 text-white px-3 py-1 text-[11px] uppercase font-bold rounded-bl-[4px] ${home.data.status.toLowerCase() === 'new' ? 'bg-accent' : 'bg-primary'}`} data-ps="src/components/home/AvailableHomes.astro:ipswiw">
                {home.data.status}
              </span>
            )}
          </div>
          <div class="p-5" data-ps="src/components/home/AvailableHomes.astro:l7th9w">
            <div class="text-[24px] font-semibold text-foreground mb-1" data-ps="src/components/home/AvailableHomes.astro:l7th9x">{home.data.price}</div>
            <div class="text-[14px] text-muted-foreground mb-3 font-medium" data-ps="src/components/home/AvailableHomes.astro:l7th9y">
              {home.data.beds && `${home.data.beds} bed`} 
              {home.data.beds && home.data.baths && ' — '}
              {home.data.baths && `${home.data.baths} bath`}
              {(home.data.beds || home.data.baths) && home.data.sqft && ' — '}
              {home.data.sqft && `${home.data.sqft} sqft`}
            </div>
            <div class="text-[14px] text-foreground font-semibold mb-4" data-ps="src/components/home/AvailableHomes.astro:l7th9z">{home.data.community || home.data.address}</div>
            <a href={`/homes/${home.slug}`} class="text-primary text-[14px] font-bold hover:underline" data-ps="src/components/home/AvailableHomes.astro:ubtf8x">View Home</a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center" data-ps="src/components/home/AvailableHomes.astro:l7th9z">
      <a href="/shop-homes" class="bg-primary text-primary-foreground font-semibold py-3 px-10 rounded-[6px] hover:bg-primary-hover transition-colors inline-block no-underline" data-ps="src/components/home/AvailableHomes.astro:grveyt">
        See All Homes
      </a>
    </div>
  </Container>
</section>

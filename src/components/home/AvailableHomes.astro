---
import Container from '@/components/Container.astro';
---

<section id="available-homes" class="bg-background py-[80px]" data-ps="src/components/home/AvailableHomes.astro:homes-gl">
  <Container class="max-w-[1200px]">
    <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4" data-ps="src/components/home/AvailableHomes.astro:igddoz">
      <div data-ps="src/components/home/AvailableHomes.astro:igddp0">
        <h2 class="text-[40px] font-semibold text-foreground leading-tight" data-ps="src/components/home/AvailableHomes.astro:yd45pt">Homes available now.</h2>
      </div>
      <a href="/shop-homes" class="text-primary font-semibold hover:underline" data-ps="src/components/home/AvailableHomes.astro:grvezl">See All Homes</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/home/AvailableHomes.astro:igddp1">
      <!-- Home 1 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/AvailableHomes.astro:igddp2">
        <div class="relative aspect-video overflow-hidden" data-ps="src/components/home/AvailableHomes.astro:igddp3">
          <img src="https://cdn.pagesmith.app/69b93246/images/EEeRzEtYqjOxEmEs-1536.webp" alt="Parsons Mobile Home Park home" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-ps="src/components/home/AvailableHomes.astro:fy49cs" />
          <span class="absolute top-0 right-0 bg-accent text-accent-foreground px-3 py-1 text-[11px] uppercase font-bold rounded-bl-[4px]" data-ps="src/components/home/AvailableHomes.astro:byzkgc">Pre-Owned</span>
        </div>
        <div class="p-5" data-ps="src/components/home/AvailableHomes.astro:igddp4">
          <div class="text-[24px] font-semibold text-foreground mb-1" data-ps="src/components/home/AvailableHomes.astro:igddp5">$29,900</div>
          <div class="text-[14px] text-muted-foreground mb-3 font-medium" data-ps="src/components/home/AvailableHomes.astro:igddp6">1 bed — 1 bath — 620 sqft</div>
          <div class="text-[14px] text-foreground font-semibold mb-4" data-ps="src/components/home/AvailableHomes.astro:igddp7">Parsons Mobile Home Park</div>
          <a href="/shop-homes" class="text-primary text-[14px] font-bold hover:underline" data-ps="src/components/home/AvailableHomes.astro:grveyz">View Home</a>
        </div>
      </div>

      <!-- Home 2 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/AvailableHomes.astro:igddp8">
        <div class="relative aspect-video overflow-hidden" data-ps="src/components/home/AvailableHomes.astro:igddpu">
          <img src="https://cdn.pagesmith.app/69b93246/images/MzDBoNlpAXtdDHNE-1536.webp" alt="Wagon Wheel home" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-ps="src/components/home/AvailableHomes.astro:fy49ct" />
          <span class="absolute top-0 right-0 bg-accent text-accent-foreground px-3 py-1 text-[11px] uppercase font-bold rounded-bl-[4px]" data-ps="src/components/home/AvailableHomes.astro:byzkgb">Pre-Owned</span>
        </div>
        <div class="p-5" data-ps="src/components/home/AvailableHomes.astro:igddpv">
          <div class="text-[24px] font-semibold text-foreground mb-1" data-ps="src/components/home/AvailableHomes.astro:igddpw">$38,500</div>
          <div class="text-[14px] text-muted-foreground mb-3 font-medium" data-ps="src/components/home/AvailableHomes.astro:igddpx">2 bed — 1 bath — 840 sqft</div>
          <div class="text-[14px] text-foreground font-semibold mb-4" data-ps="src/components/home/AvailableHomes.astro:igddpy">Wagon Wheel</div>
          <a href="/shop-homes" class="text-primary text-[14px] font-bold hover:underline" data-ps="src/components/home/AvailableHomes.astro:grveyy">View Home</a>
        </div>
      </div>

      <!-- Home 3 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/AvailableHomes.astro:igddpz">

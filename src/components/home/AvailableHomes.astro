          <img src="https://cdn.pagesmith.app/69b93246/images/XREDZLGBDyPuZTzy-1536.webp" alt="Parsons Mobile Home Park home" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-ps="src/components/home/AvailableHomes.astro:fy49cu" />
          <span class="absolute top-0 right-0 bg-accent text-accent-foreground px-3 py-1 text-[11px] uppercase font-bold rounded-bl-[4px]" data-ps="src/components/home/AvailableHomes.astro:byzkga">Pre-Owned</span>
        </div>
        <div class="p-5" data-ps="src/components/home/AvailableHomes.astro:igddq1">
          <div class="text-[24px] font-semibold text-foreground mb-1" data-ps="src/components/home/AvailableHomes.astro:igddq2">$47,900</div>
          <div class="text-[14px] text-muted-foreground mb-3 font-medium" data-ps="src/components/home/AvailableHomes.astro:igddq3">2 bed — 1 bath — 864 sqft</div>
          <div class="text-[14px] text-foreground font-semibold mb-4" data-ps="src/components/home/AvailableHomes.astro:igddqp">Parsons Mobile Home Park</div>
          <a href="/shop-homes" class="text-primary text-[14px] font-bold hover:underline" data-ps="src/components/home/AvailableHomes.astro:grveyx">View Home</a>
        </div>
      </div>

      <!-- Home 4 -->
      <div class="bg-surface rounded-[8px] border border-border overflow-hidden group hover:-translate-y-1 hover:shadow-md transition-all" data-ps="src/components/home/AvailableHomes.astro:igddqq">
        <div class="relative aspect-video overflow-hidden" data-ps="src/components/home/AvailableHomes.astro:igddqr">

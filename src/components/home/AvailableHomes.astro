        </div>
      </div>
    </div>

    <div class="mt-12 text-center" data-ps="src/components/home/AvailableHomes.astro:l7th9z">
      <a href="/shop-homes" class="bg-primary text-primary-foreground font-semibold py-3 px-10 rounded-[6px] hover:bg-primary-hover transition-colors inline-block no-underline" data-ps="src/components/home/AvailableHomes.astro:grveyt">
        See All Homes

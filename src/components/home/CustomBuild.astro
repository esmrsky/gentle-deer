---
import Container from '@/components/Container.astro';
---

<section id="custom-build" class="bg-primary py-[100px] text-white" data-ps="src/components/home/CustomBuild.astro:custom-gl">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center" data-ps="src/components/home/CustomBuild.astro:bgrm6w">
      <div data-ps="src/components/home/CustomBuild.astro:8smuw0">
        <span class="text-white/70 text-[12px] font-bold tracking-[0.2em] uppercase mb-4 block" data-ps="src/components/home/CustomBuild.astro:1x79h5">Build New</span>
        <h2 class="text-[40px] font-semibold text-white leading-tight mb-6" data-ps="src/components/home/CustomBuild.astro:hxo6pr">Order your home exactly the way you want it.</h2>
        <p class="text-[18px] text-white/90 leading-relaxed mb-10" data-ps="src/components/home/CustomBuild.astro:z5j6e8">
          As a proud dealer of Redman Homes and Adventure Homes, we can help you design and order a brand new manufactured home built to your specifications. Choose your floor plan, finishes, and features.
        </p>
        <a href="/contact" class="bg-surface text-primary font-bold py-4 px-8 rounded-[6px] hover:bg-secondary transition-colors inline-block no-underline" data-ps="src/components/home/CustomBuild.astro:srmyv4">
          Start a Custom Build
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/home/CustomBuild.astro:8smuw1">
        <div class="bg-white/10 border border-white/20 rounded-[8px] p-6" data-ps="src/components/home/CustomBuild.astro:8smuw2">
          <div class="text-white mb-4" data-ps="src/components/home/CustomBuild.astro:8smuw3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-template"><rect width="18" height="7" x="3" y="3" rx="1"/><rect width="9" height="7" x="3" y="14" rx="1"/><rect width="5" height="7" x="16" y="14" rx="1"/></svg>
          </div>
          <h3 class="text-[18px] font-semibold mb-2" data-ps="src/components/home/CustomBuild.astro:3999i3">Custom floor plans</h3>
        </div>
        <div class="bg-white/10 border border-white/20 rounded-[8px] p-6" data-ps="src/components/home/CustomBuild.astro:8smuw4">
          <div class="text-white mb-4" data-ps="src/components/home/CustomBuild.astro:8smuw5">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-palette"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.92 0 1.7-.39 2.3-1.03.35-.37.6-.83.7-1.34.02-.13.02-.27.1-.44.41-1 1.56-1.05 2.1-1.05h.8c1.1 0 2-.9 2-2 0-3.13-2.78-5.73-5.85-6.13a10.2 10.2 0 0 0-4.15 0C8.12 10.4 6 12.87 6 15.87"/></svg>
          </div>
          <h3 class="text-[18px] font-semibold mb-2" data-ps="src/components/home/CustomBuild.astro:3999i4">Choose your finishes</h3>
        </div>
        <div class="bg-white/10 border border-white/20 rounded-[8px] p-6" data-ps="src/components/home/CustomBuild.astro:8smuw6">
          <div class="text-white mb-4" data-ps="src/components/home/CustomBuild.astro:8smuw7">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap"><path d="M4 14.5L14 3 12 9.5H20L10 21l2-6.5H4z"/></svg>
          </div>
          <h3 class="text-[18px] font-semibold mb-2" data-ps="src/components/home/CustomBuild.astro:3999i5">Energy efficient builds</h3>
        </div>
        <div class="bg-white/10 border border-white/20 rounded-[8px] p-6" data-ps="src/components/home/CustomBuild.astro:8smuw8">
          <div class="text-white mb-4" data-ps="src/components/home/CustomBuild.astro:8smuw9">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3 class="text-[18px] font-semibold mb-2" data-ps="src/components/home/CustomBuild.astro:3999i6">Manufacturer warranty</h3>
        </div>
      </div>
    </div>
  </Container>
</section>

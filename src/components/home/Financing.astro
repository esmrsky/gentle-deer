---
import Container from '@/components/Container.astro';
---

<section id="financing" class="bg-background py-[100px]" data-ps="src/components/home/Financing.astro:fin-gl">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start" data-ps="src/components/home/Financing.astro:y3x4uh">
      <div data-ps="src/components/home/Financing.astro:y3x4ui">
        <span class="text-accent text-[12px] font-bold tracking-[0.2em] uppercase mb-4 block" data-ps="src/components/home/Financing.astro:j6j1m2">Financing</span>
        <h2 class="text-[40px] font-semibold text-foreground leading-tight mb-6" data-ps="src/components/home/Financing.astro:npnljk">Homes from $X,XXX a month.</h2>
        <p class="text-[16px] text-foreground/80 leading-relaxed mb-8" data-ps="src/components/home/Financing.astro:yfzfuo">
          We work with trusted local lenders who understand manufactured home financing. Most of our buyers are surprised how affordable the monthly payment actually is. Get prequalified in minutes with no impact to your credit score.
        </p>
        
        <ul class="space-y-4 mb-10">
          <li class="flex items-start gap-3" data-ps="src/components/home/Financing.astro:o183gv">
            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-[16px]" data-ps="src/components/home/Financing.astro:j6j1m1">No impact to your credit to prequalify</span>
          </li>
          <li class="flex items-start gap-3" data-ps="src/components/home/Financing.astro:o183gu">
            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-[16px]" data-ps="src/components/home/Financing.astro:j6j1m0">Loan options for first-time buyers</span>
          </li>
          <li class="flex items-start gap-3" data-ps="src/components/home/Financing.astro:o183gt">
            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-[16px]" data-ps="src/components/home/Financing.astro:j6j1lz">Our team walks you through every step</span>
          </li>
        </ul>

        <a href="/contact?path=D" class="bg-primary text-primary-foreground font-semibold py-3 px-6 rounded-[6px] hover:bg-primary-hover transition-colors inline-block no-underline" data-ps="src/components/home/Financing.astro:th6per">
          Start Prequalification
        </a>
      </div>

      <div class="bg-surface p-8 rounded-[8px] shadow-sm border border-border w-full" data-ps="src/components/home/Financing.astro:y3x4uj">
        <h3 class="text-[20px] font-semibold text-foreground mb-6" data-ps="src/components/home/Financing.astro:o6p8oh">Quick Prequalification</h3>
        <form class="space-y-4">
          <div class="space-y-2" data-ps="src/components/home/Financing.astro:y3x4uk">
            <label class="text-[14px] font-semibold text-foreground" data-ps="src/components/home/Financing.astro:2u83h6">Are you paying cash or financing?</label>
            <select class="w-full px-4 py-2.5 bg-background border border-border rounded-[4px] focus:outline-none focus:ring-2 focus:ring-primary/20">
              <option>Select...</option>
              <option>Paying cash</option>
              <option>Financing</option>
              <option>Not sure</option>
            </select>
          </div>
          <div class="space-y-2" data-ps="src/components/home/Financing.astro:y3x4ul">
            <label class="text-[14px] font-semibold text-foreground" data-ps="src/components/home/Financing.astro:2u83h5">Credit range</label>
            <select class="w-full px-4 py-2.5 bg-background border border-border rounded-[4px] focus:outline-none focus:ring-2 focus:ring-primary/20">
              <option>Select...</option>
              <option>Excellent</option>
              <option>Good</option>
              <option>Fair</option>
              <option>Building credit</option>
              <option>Not sure</option>
            </select>
          </div>
          <div class="space-y-2" data-ps="src/components/home/Financing.astro:y3x4um">
            <label class="text-[14px] font-semibold text-foreground" data-ps="src/components/home/Financing.astro:2u83h4">Employment</label>
            <select class="w-full px-4 py-2.5 bg-background border border-border rounded-[4px] focus:outline-none focus:ring-2 focus:ring-primary/20">
              <option>Select...</option>
              <option>Full-time</option>
              <option>Part-time</option>
              <option>Self-employed</option>
              <option>Retired</option>
              <option>Other</option>
            </select>
          </div>
          <div class="space-y-2" data-ps="src/components/home/Financing.astro:y3x4un">
            <label class="text-[14px] font-semibold text-foreground" data-ps="src/components/home/Financing.astro:2u83h3">Email</label>
            <input type="email" placeholder="your@email.com" class="w-full px-4 py-2.5 bg-background border border-border rounded-[4px] focus:outline-none focus:ring-2 focus:ring-primary/20" />
          </div>
          <button type="button" class="w-full bg-primary text-primary-foreground font-semibold py-3.5 rounded-[6px] hover:bg-primary-hover transition-colors mt-2" data-ps="src/components/home/Financing.astro:k3lo7o">
            See What I Qualify For
          </button>
          <p class="text-[12px] text-muted-foreground text-center mt-4" data-ps="src/components/home/Financing.astro:euxa6g">
            This is not a hard inquiry on your credit and will not affect your credit score.
          </p>
        </form>
      </div>
    </div>
  </Container>
</section>

---
import Container from '@/components/Container.astro';
---

<section id="right-home" class="bg-background py-[80px]" data-ps="src/components/home/RightHome.astro:right-home-gl">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center" data-ps="src/components/home/RightHome.astro:omj93c">
      <div class="reveal-left" data-ps="src/components/home/RightHome.astro:omj93d">
        <span class="text-accent text-[12px] font-bold tracking-[0.2em] uppercase mb-4 block" data-ps="src/components/home/RightHome.astro:aazudx">Central Ohio Living</span>
        <h2 class="text-[40px] font-semibold text-foreground leading-[1.2] mb-6" data-ps="src/components/home/RightHome.astro:dyrumq">The right home for every chapter.</h2>
        <div class="space-y-4 text-[18px] text-foreground/80 leading-relaxed" data-ps="src/components/home/RightHome.astro:omj93e">
          <p data-ps="src/components/home/RightHome.astro:swuw92">
            Whether you are just starting out, raising a family, or looking for a quieter pace, Greenlawn has a community and a home that fits.
          </p>
          <p data-ps="src/components/home/RightHome.astro:swuw93">
            From lakeside retreats to established Central Ohio neighborhoods, our nine communities span the region and every stage of life.
          </p>
        </div>
      </div>
      <div class="reveal-right" data-ps="src/components/home/RightHome.astro:omj93f">
        <img 
          src="https://cdn.pagesmith.app/69b93246/images/hero-community-ad9AFtHhG4fpSz2z6YeCHE-1536.webp" 
          alt="Central Ohio Community Lifestyle" 
          class="w-full aspect-4/3 object-cover rounded-[8px] shadow-lg" data-ps="src/components/home/RightHome.astro:58ppjx" />
      </div>
    </div>
  </Container>
</section>

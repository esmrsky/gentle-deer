---
import Container from '@/components/Container.astro';
import { SITE } from '@/config/site';
---

<section id="hero" class="relative min-h-[720px] flex items-center py-[120px] overflow-hidden" data-ps="src/components/home/Hero.astro:hero-gl">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0" data-ps="src/components/home/Hero.astro:ecxgfa">
    <img 
      src="https://cdn.pagesmith.app/69b93246/images/hero-community-ad9AFtHhG4fpSz2z6YeCHE-1536.webp" 
      alt="Greenlawn Homes Community" 
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high" data-ps="src/components/home/Hero.astro:fibi7z" />
    <div class="absolute inset-0 bg-linear-to-b from-black/68 to-black/38" data-ps="src/components/home/Hero.astro:ecxgfb"></div>
  </div>

  <Container class="relative z-10 max-w-[1200px]">
    <div class="max-w-[700px] text-left" data-ps="src/components/home/Hero.astro:ecxgfc">
      <h1 class="text-[56px] md:text-[64px] font-bold text-white leading-[1.1] mb-6 hero-animate" data-ps="src/components/home/Hero.astro:hero-h1">
        Homeownership, the way it should be.
      </h1>
      <p class="text-[20px] text-white/90 font-normal leading-relaxed mb-10 hero-animate hero-animate-delay-1" data-ps="src/components/home/Hero.astro:hero-p">
        A family-run Central Ohio manufactured home dealer and community operator. Proud dealer of Redman Homes and Adventure Homes.
      </p>
      <div class="flex flex-wrap gap-4 hero-animate hero-animate-delay-2" data-ps="src/components/home/Hero.astro:hero-btns">
        <a href="/shop-homes" class="bg-primary text-primary-foreground font-semibold py-3 px-6 rounded-[6px] hover:bg-primary-hover transition-colors no-underline" data-ps="src/components/home/Hero.astro:iblyyl">
          Shop Available Homes
        </a>
        <a href="/#our-communities" class="border-2 border-white text-white font-semibold py-3 px-8 rounded-[6px] hover:bg-white hover:text-dark transition-all no-underline" data-ps="src/components/home/Hero.astro:iblyyk">
          Explore Our Communities
        </a>
      </div>
    </div>
  </Container>
</section>

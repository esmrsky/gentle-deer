---
import Container from '@/components/Container.astro';
import { SITE } from '@/config/site';
---

<footer class="bg-dark text-dark-muted py-[80px]" data-ps="src/components/Footer.astro:footer-gl">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16" data-ps="src/components/Footer.astro:p4vf83">
      <!-- Column 1: Info -->
      <div class="space-y-6" data-ps="src/components/Footer.astro:p4vf84">
        <img src="https://cdn.pagesmith.app/69b93246/images/greenlawn-logo-color_6d9219bc-1024.webp" alt={SITE.name} width="152" height="56" class="h-14 w-auto rounded-[8px]" data-ps="src/components/Footer.astro:4qdjf6" />
        <p class="text-[15px] leading-relaxed max-w-xs" data-ps="src/components/Footer.astro:csfal">
          A family-run Central Ohio manufactured home dealer and community operator. Proud dealer of Redman Homes and Adventure Homes.
        </p>
        <div class="space-y-2" data-ps="src/components/Footer.astro:p4vf85">
          <a href="tel:6144437421" class="block text-white font-bold text-[18px] no-underline hover:text-accent transition-colors" data-ps="src/components/Footer.astro:7gqbyq">(614) 443-7421</a>
          <p class="text-[14px]" data-ps="src/components/Footer.astro:csfam">M–F 9am–5pm</p>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div data-ps="src/components/Footer.astro:p4vf86">
        <h4 class="text-accent text-[12px] uppercase tracking-[0.2em] font-bold mb-6" data-ps="src/components/Footer.astro:2uqr9o">Quick Links</h4>
        <ul class="flex flex-col gap-3 list-none p-0 m-0">
          <li data-ps="src/components/Footer.astro:wyji40"><a href="/shop-homes" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbyr">Shop Homes</a></li>
          <li data-ps="src/components/Footer.astro:wyji41"><a href="/communities" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbys">Communities</a></li>
          <li data-ps="src/components/Footer.astro:wyji42"><a href="/our-story" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbyt">Our Story</a></li>
          <li data-ps="src/components/Footer.astro:wyji4o"><a href="/contact" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbyu">Contact</a></li>
          <li data-ps="src/components/Footer.astro:wyji4p"><a href="/contact?path=D" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbyv">Get Prequalified</a></li>
          <li data-ps="src/components/Footer.astro:wyji4q"><a href="/contact?path=B" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbyw">Build New</a></li>
          <li data-ps="src/components/Footer.astro:wyji4r"><a href="/companies" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzi">Greenlawn Companies ↗</a></li>
        </ul>
      </div>

      <!-- Column 3: Our Communities -->
      <div data-ps="src/components/Footer.astro:p4vf87">
        <h4 class="text-accent text-[12px] uppercase tracking-[0.2em] font-bold mb-6" data-ps="src/components/Footer.astro:2uqr9p">Our Communities</h4>
        <div class="grid grid-cols-1 gap-x-8 gap-y-3" data-ps="src/components/Footer.astro:p4vf88">
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            <li data-ps="src/components/Footer.astro:wyji4s"><a href="/communities/big-run-bluffs" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzj">Big Run Bluffs</a></li>
            <li data-ps="src/components/Footer.astro:wyji4t"><a href="/communities/enchanted-acres" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzk">Enchanted Acres</a></li>
            <li data-ps="src/components/Footer.astro:wyji4u"><a href="/communities/parsons-mobile-home-park" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzl">Parsons Mobile Home Park</a></li>
            <li data-ps="src/components/Footer.astro:wyji4v"><a href="/communities/casal-court" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzm">Casal Court</a></li>
            <li data-ps="src/components/Footer.astro:wyji4w"><a href="/communities/foxlair-farms" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzn">Foxlair Farms</a></li>
            <li data-ps="src/components/Footer.astro:wyji4x"><a href="/communities/buckeye-lake-estates" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzo">Buckeye Lake Estates</a></li>
            <li data-ps="src/components/Footer.astro:wyji5j"><a href="/communities/willowbrook-terrace" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzp">Willowbrook Terrace</a></li>
            <li data-ps="src/components/Footer.astro:wyji5k"><a href="/communities/washington-manor" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzq">Washington Manor</a></li>
            <li data-ps="src/components/Footer.astro:wyji5l"><a href="/communities/wagon-wheel" class="text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqbzr">Wagon Wheel</a></li>
          </ul>
        </div>
      </div>

      <!-- Column 4: Contact -->
      <div data-ps="src/components/Footer.astro:p4vf89">
        <h4 class="text-accent text-[12px] uppercase tracking-[0.2em] font-bold mb-6" data-ps="src/components/Footer.astro:2uqr9q">Contact</h4>
        <div class="space-y-4" data-ps="src/components/Footer.astro:p4vf8a">
          <p class="text-[15px]" data-ps="src/components/Footer.astro:csfan">Central Ohio</p>
          <a href="tel:6144437421" class="block text-[15px] text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0d">(614) 443-7421</a>
          <a href="/contact" class="inline-block text-accent text-[15px] font-bold no-underline hover:underline" data-ps="src/components/Footer.astro:7gqc0e">Send us a message →</a>
        </div>
      </div>
    </div>

    <div class="border-t border-dark-border pt-10 flex flex-col md:flex-row justify-between items-center gap-6" data-ps="src/components/Footer.astro:p4vf8b">
      <p class="text-[14px] text-dark-muted" data-ps="src/components/Footer.astro:csfao">
        © {new Date().getFullYear()} {SITE.name}. All rights reserved. 
        <a href="/login/" class="ml-2 hover:text-accent transition-colors" data-ps="src/components/Footer.astro:8o2pm">Admin Login</a>
      </p>
      <p class="text-[14px] text-dark-muted font-medium" data-ps="src/components/Footer.astro:csfap">
        Proud dealer of Redman Homes & Adventure Homes
      </p>
      <p class="text-[14px] text-dark-muted" data-ps="src/components/Footer.astro:euot">Made with Manus</p>
    </div>
  </Container>
</footer>

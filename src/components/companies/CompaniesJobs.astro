---
import Container from '@/components/Container.astro';
---

<section id="jobs" class="bg-background py-[80px]">
  <Container class="max-w-[800px] text-center">
    <h2 class="text-[40px] font-serif font-semibold text-foreground mb-6">Join Our Team</h2>
    <p class="text-[18px] text-muted-foreground leading-relaxed mb-8">
      We're always looking for people who take pride in their work and want to be part of something that matters to their community. Whether you're interested in sales, community management, transport, or operations, Greenlawn Companies offers a team-first culture, competitive pay, and the satisfaction of helping Central Ohio families find their place to call home.
    </p>
    <a href="#" class="bg-primary text-primary-foreground rounded-[6px] px-[20px] py-[10px] text-[14px] font-semibold inline-flex items-center justify-center hover:bg-primary-hover transition-colors">
      View Open Positions
    </a>
  </Container>
</section>

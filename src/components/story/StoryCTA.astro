---
import Container from '@/components/Container.astro';
---

<section id="story-cta" class="bg-background py-[80px]">
  <Container class="max-w-[800px] text-center">
    <h2 class="text-[40px] font-serif font-semibold text-foreground mb-6">Ready to find your home?</h2>
    <p class="text-[18px] text-muted-foreground mb-8">
      Browse our available homes or reach out to our team. We would love to help.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/shop-homes" class="bg-primary text-primary-foreground rounded-[6px] px-[20px] py-[10px] text-[14px] font-semibold inline-flex items-center justify-center hover:bg-primary-hover transition-colors">
        Shop Homes
      </a>
      <a href="/contact" class="bg-surface text-foreground border border-border rounded-[6px] px-[20px] py-[10px] text-[14px] font-semibold inline-flex items-center justify-center hover:bg-secondary transition-colors">
        Get in Touch
      </a>
    </div>
  </Container>
</section>

---
import Container from '@/components/Container.astro';
---

<section id="values" class="bg-secondary py-[80px]">
  <Container class="max-w-[1200px]">
    <h2 class="text-[40px] font-serif font-semibold text-foreground text-center mb-16">What we believe in.</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-surface rounded-[8px] border border-border p-8">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="text-[24px] font-serif font-semibold text-foreground mb-3">Integrity first.</h3>
        <p class="text-[16px] text-muted-foreground leading-relaxed">
          We stand behind every home we sell. If something is wrong, we make it right. That is not a policy — it is how we were raised.
        </p>
      </div>

      <div class="bg-surface rounded-[8px] border border-border p-8">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <h3 class="text-[24px] font-serif font-semibold text-foreground mb-3">Community matters.</h3>
        <p class="text-[16px] text-muted-foreground leading-relaxed">
          We do not just sell homes. We build neighborhoods. The communities we operate are places we are proud to put our name on.
        </p>
      </div>

      <div class="bg-surface rounded-[8px] border border-border p-8">
        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <h3 class="text-[24px] font-serif font-semibold text-foreground mb-3">Homeownership for everyone.</h3>
        <p class="text-[16px] text-muted-foreground leading-relaxed">
          We believe a manufactured home is a real home. We work hard to make it accessible to every family who wants one.
        </p>
      </div>
    </div>
  </Container>
</section>

---
import Container from '@/components/Container.astro';
---

<section id="mission" class="bg-primary py-[80px]">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-accent text-[12px] font-bold tracking-widest uppercase mb-4">OUR MISSION</p>
        <h2 class="text-[40px] font-serif font-semibold text-primary-foreground mb-6">
          We believe homeownership should be within reach for everyone.
        </h2>
      </div>
      <div>
        <p class="text-[18px] text-primary-foreground/90 leading-relaxed">
          Manufactured homes are real homes. They are where families grow, memories are made, and roots are put down. Greenlawn exists to make that possible for as many Central Ohio families as we can.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-16 pt-16 border-t border-primary-foreground/20">
      <div class="text-center">
        <p class="text-[48px] font-serif font-semibold text-primary-foreground mb-2">40+</p>
        <p class="text-[12px] font-bold tracking-wider uppercase text-primary-foreground/70">YEARS IN BUSINESS</p>
      </div>
      <div class="text-center">
        <p class="text-[48px] font-serif font-semibold text-primary-foreground mb-2">9</p>
        <p class="text-[12px] font-bold tracking-wider uppercase text-primary-foreground/70">COMMUNITIES</p>
      </div>
      <div class="text-center">
        <p class="text-[48px] font-serif font-semibold text-primary-foreground mb-2">2,000+</p>
        <p class="text-[12px] font-bold tracking-wider uppercase text-primary-foreground/70">FAMILIES HOUSED</p>
      </div>
      <div class="text-center">
        <p class="text-[48px] font-serif font-semibold text-primary-foreground mb-2">Family-Run</p>
        <p class="text-[12px] font-bold tracking-wider uppercase text-primary-foreground/70">SINCE DAY ONE</p>
      </div>
    </div>
  </Container>
</section>

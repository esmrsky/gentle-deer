---
import Container from '@/components/Container.astro';
---

<section id="story-hero" class="bg-dark pt-[80px] pb-[100px]">
  <Container class="max-w-[1200px]">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-accent text-[12px] font-bold tracking-widest uppercase mb-4">OUR STORY</p>
        <h1 class="text-[56px] font-serif font-semibold text-dark-foreground leading-[1.1] mb-6">
          A family business, built for families.
        </h1>
        <p class="text-[20px] text-dark-muted leading-relaxed">
          Over 40 years of helping Central Ohio families find a home they can afford and a community they can be proud of.
        </p>
      </div>
      <div>
        <img
          src="https://cdn.pagesmith.app/69b93246/images/judhpwyXPDYlhlaH-1536.webp"
          alt="Greenlawn family history"
          class="w-full rounded-[8px] object-cover aspect-[4/3]"
        />
      </div>
    </div>
  </Container>
</section>

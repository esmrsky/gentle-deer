---
export interface Props {
  features: Array<{ label: string; description: string }>;
}

const { features } = Astro.props;
---

<section class="py-16 md:py-20 bg-background">
  <div class="max-w-[1200px] mx-auto px-6">
    <h2 class="text-[28px] font-semibold text-foreground mb-10">
      What you get here.
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-6">
      {features.map((feature) => (
        <div class="flex items-start gap-3">
          <div class="w-5 h-5 mt-0.5 flex-shrink-0">
            <svg viewBox="0 0 20 20" fill="currentColor" class="w-full h-full text-primary">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-[14px] font-semibold text-foreground leading-snug">{feature.label}</p>
            {feature.description && (
              <p class="text-[13px] text-muted-foreground mt-0.5">{feature.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
export interface Props {
  phone: string;
  managerName: string;
  communityName: string;
}

const { phone, managerName, communityName } = Astro.props;
---

<section class="py-16 md:py-20 bg-secondary">
  <div class="max-w-[1200px] mx-auto px-6">
    <h2 class="text-[28px] font-semibold text-foreground mb-2">
      Already a Resident?
    </h2>

    <p class="text-muted-foreground mb-8">
      Your community manager <strong class="text-foreground">{managerName}</strong> is here to help with payments, maintenance, and anything else you need.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <a
        href={`tel:${phone.replace(/\D/g, '')}`}
        class="bg-surface rounded-[8px] p-5 border border-border hover:-translate-y-0.5 hover:shadow-md transition-all"
      >
        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <p class="text-[14px] font-semibold text-foreground mb-1">Contact Your Manager</p>
        <p class="text-[14px] text-primary font-semibold">{phone}</p>
      </a>

      <div class="bg-surface rounded-[8px] p-5 border border-border opacity-75">
        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <p class="text-[14px] font-semibold text-foreground mb-1">Pay Rent</p>
        <p class="text-[13px] text-muted-foreground">Pay your monthly lot rent online or by phone.</p>
        <p class="text-[12px] text-muted-foreground mt-2 italic">(coming soon)</p>
      </div>

      <div class="bg-surface rounded-[8px] p-5 border border-border opacity-75">
        <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <p class="text-[14px] font-semibold text-foreground mb-1">Maintenance Request</p>
        <p class="text-[13px] text-muted-foreground">Submit a maintenance request for community grounds or your home.</p>
        <p class="text-[12px] text-muted-foreground mt-2 italic">(coming soon)</p>
      </div>

      <a
        href="tel:EMERGENCY_LINE_TBD"
        class="bg-surface rounded-[8px] p-5 border border-border hover:-translate-y-0.5 hover:shadow-md transition-all"
      >
        <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <p class="text-[14px] font-semibold text-foreground mb-1">After-Hours Emergency</p>
        <p class="text-[13px] text-muted-foreground">For urgent issues outside of regular office hours.</p>
      </a>
    </div>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/#"
        class="inline-flex items-center gap-2 text-primary text-[14px] font-semibold hover:underline"
      >
        Community Suggestion Box
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

      <span class="text-border">|</span>

      <a
        href={`tel:${phone.replace(/\D/g, '')}`}
        class="inline-flex items-center gap-2 text-primary text-[14px] font-semibold hover:underline"
      >
        Request a Call Back
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <p class="text-[14px] text-muted-foreground mt-6">
      Questions about your community? Call your property manager directly at <a href={`tel:${phone.replace(/\D/g, '')}`} class="text-primary font-semibold hover:underline">{phone}</a>
    </p>
  </div>
</section>
